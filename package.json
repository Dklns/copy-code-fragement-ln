{
  "name": "copy-code-fragment-ln",
  "displayName": "Copy Code Fragment LN",
  "description": "Copy the relative file path and selected line ranges from the active editor.",
  "version": "0.0.1",
  "publisher": "Dklns",
  "author": "Dklns",
  "license": "MIT",
  "homepage": "https://github.com/Dklns/copy-code-fragement-ln",
  "repository": {
    "type": "git",
    "url": "https://github.com/Dklns/copy-code-fragement-ln.git"
  },
  "bugs": {
    "url": "https://github.com/Dklns/copy-code-fragement-ln/issues"
  },
  "engines": {
    "vscode": "^1.116.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "copy",
    "snippet",
    "path",
    "line-number",
    "selection"
  ],
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#121C33",
    "theme": "dark"
  },
  "markdown": "github",
  "activationEvents": [
    "onCommand:copyCodeFragmentLn.copyLocation"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "copyCodeFragmentLn.copyLocation",
        "title": "复制代码片段定位",
        "category": "Copy Code Fragment LN"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "copyCodeFragmentLn.copyLocation",
          "when": "editorTextFocus && editorHasSelection && resourceScheme == file",
          "group": "9_cutcopypaste@10"
        }
      ]
    },
    "keybindings": [
      {
        "command": "copyCodeFragmentLn.copyLocation",
        "key": "ctrl+shift+c",
        "mac": "cmd+shift+c",
        "when": "editorTextFocus && editorHasSelection && resourceScheme == file"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "node ./out/test/runTest.js",
    "package": "npm run compile && npx @vscode/vsce package"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.116.0",
    "@vscode/vsce": "^3.9.1",
    "@vscode/test-electron": "^2.5.2",
    "mocha": "^11.7.5",
    "typescript": "^6.0.3"
  }
}
